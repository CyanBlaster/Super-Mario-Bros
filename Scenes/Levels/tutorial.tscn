[node name="Label" type="Label" parent="."]
offset_left = -322.0
offset_top = 463.0
offset_right = -16.0
offset_bottom = 590.0
text = "            Welcome to the Tutorial!
Feel free to skip it with the goal item
             on your left if needed.
If you cannot, then use your arrow keys
              to continue on right."

[node name="Label2" type="Label" parent="."]
offset_left = 270.0
offset_top = 533.0
offset_right = 483.0
offset_bottom = 556.0
text = "Use Z to Jump over the gap!"

[node name="Label3" type="Label" parent="."]
offset_left = 648.0
offset_top = 533.0
offset_right = 948.0
offset_bottom = 582.0
text = "Now, hold X to sprint, and then press Z
to overcome the gap!"

[node name="Label4" type="Label" parent="."]
offset_left = 1206.0
offset_top = 515.0
offset_right = 1374.0
offset_bottom = 590.0
text = "Oh no, a Goomba! 
Jump on it to brutally
mur- I mean defeat it!"

[node name="Label5" type="Label" parent="."]
offset_left = 1901.0
offset_top = 488.0
offset_right = 2210.0
offset_bottom = 593.0
text = "Injured? Collect coins to recover your
 lifebar on the top right of your screen. 
Don't worry, you'll have plenty of
 opportunities to collect coins if needed!"

[node name="Label6" type="Label" parent="."]
offset_left = 2704.0
offset_top = 513.0
offset_right = 3020.0
offset_bottom = 588.0
text = "Now let's get into powerups. See that
leaf over there? Grab it, and then spam Z
to glide across the gap!"

[node name="Label7" type="Label" parent="."]
offset_left = 3349.0
offset_top = 568.0
offset_right = 3771.0
offset_bottom = 643.0
text = "That flower allows you to shoot fireballs that can
melt even the coldest of ice! Press X to fire burning 
hot fireballs at foes!"

[node name="Label8" type="Label" parent="."]
offset_left = 4178.0
offset_top = 551.0
offset_right = 4510.0
offset_bottom = 652.0
text = "You'll also be able to get coins and 
other powerups from this various boxes. 
Try to see what they give you on their own!
 They're also randomized btw"

[node name="Label9" type="Label" parent="."]
offset_left = 5078.0
offset_top = 546.0
offset_right = 5319.0
offset_bottom = 621.0
text = "Well, that's all the advice I can
provide. Now, go grab that orb 
and find that princess!"

[node name="Label10" type="Label" parent="."]
offset_left = 4715.0
offset_top = 586.0
offset_right = 4982.0
offset_bottom = 661.0
text = "If you hate music for some reason,
            press M to Mute it!"

